---
import { getCollection, render } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.tsx';
import Footer from '../../../components/Footer.tsx';

export async function getStaticPaths() {
    const posts = await getCollection('blog');
    return posts.map((post) => ({
        params: { slug: post.slug },
        props: post,
    }));
}

const post = Astro.props;
const { Content } = await render(post);
---

<Layout title={`${post.data.title} - NornCorp`} description={post.data.description}>
    <Header client:load />

    <main class="isolate">
        <article class="bg-norn-dark py-24 sm:py-32">
            <div class="mx-auto max-w-3xl px-6 lg:px-8">
                <div class="mb-8">
                    <a href="/resources/blog" class="text-sm text-norn-green hover:text-norn-green-light">
                        &larr; Back to Blog
                    </a>
                </div>
                <header class="mb-12">
                    <div class="flex items-center gap-x-4 text-sm">
                        <time datetime={post.data.pubDate.toISOString()} class="text-gray-500">
                            {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                        </time>
                        <span class="rounded-full bg-norn-green/10 px-3 py-1.5 font-medium text-norn-green">
                            {post.data.category}
                        </span>
                    </div>
                    <h1 class="mt-6 text-4xl font-semibold tracking-tight text-white sm:text-5xl">
                        {post.data.title}
                    </h1>
                    <p class="mt-4 text-lg text-gray-400">
                        {post.data.description}
                    </p>
                    <div class="mt-6 border-t border-white/10 pt-6">
                        <p class="text-sm text-gray-400">
                            By <span class="font-semibold text-white">{post.data.author}</span>
                        </p>
                    </div>
                </header>
                <div class="prose prose-invert prose-green max-w-none
                    prose-headings:text-white prose-headings:font-semibold
                    prose-p:text-gray-300
                    prose-a:text-norn-green prose-a:no-underline hover:prose-a:text-norn-green-light
                    prose-strong:text-white
                    prose-code:text-norn-green prose-code:bg-norn-darker prose-code:rounded prose-code:px-1.5 prose-code:py-0.5
                    prose-pre:bg-[#0a0f0d] prose-pre:border prose-pre:border-white/10
                    prose-pre:prose-code:bg-transparent prose-pre:prose-code:p-0
                    prose-li:text-gray-300
                    prose-blockquote:border-norn-green prose-blockquote:text-gray-400">
                    <Content />
                </div>
                {post.data.tags && post.data.tags.length > 0 && (
                    <div class="mt-12 border-t border-white/10 pt-8">
                        <div class="flex flex-wrap gap-2">
                            {post.data.tags.map((tag: string) => (
                                <span class="rounded-full bg-norn-green/10 px-3 py-1 text-xs font-medium text-norn-green">
                                    {tag}
                                </span>
                            ))}
                        </div>
                    </div>
                )}
            </div>
        </article>
    </main>

    <Footer />
</Layout>
