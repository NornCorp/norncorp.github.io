---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.tsx';
import Footer from '../../../components/Footer.tsx';
import BlogPostCard from '../../../components/BlogPostCard.astro';

const posts = (await getCollection('blog')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout title="Blog - NornCorp" description="Security insights, product updates, and best practices from the NornCorp team.">
    <Header client:load />

    <main class="isolate">
        <div class="bg-norn-dark py-24 sm:py-32">
            <div class="mx-auto max-w-7xl px-6 lg:px-8">
                <div class="max-w-2xl">
                    <h1 class="text-4xl font-semibold tracking-tight text-white sm:text-5xl">
                        Blog
                    </h1>
                    <p class="mt-4 text-lg text-gray-400">
                        Security insights, product updates, and best practices from our team.
                    </p>
                </div>
                <div class="mx-auto mt-16 grid max-w-2xl grid-cols-1 gap-8 lg:mx-0 lg:max-w-none lg:grid-cols-3">
                    {posts.map((post) => (
                        <BlogPostCard
                            title={post.data.title}
                            description={post.data.description}
                            pubDate={post.data.pubDate}
                            author={post.data.author}
                            category={post.data.category}
                            slug={post.slug}
                        />
                    ))}
                </div>
            </div>
        </div>
    </main>

    <Footer />
</Layout>
