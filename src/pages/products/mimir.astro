---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.tsx';
import Footer from '../../components/Footer.tsx';
import ProductHero from '../../components/ProductHero.tsx';
import PricingTable from '../../components/PricingTable.tsx';

const pricingTiers = [
    {
        name: 'Starter',
        price: '$99',
        period: '/month',
        description: 'For small teams getting started with secrets management.',
        features: ['Up to 1,000 secrets', '5 users included', 'Core secrets engine', 'Basic audit logging', 'Community support'],
        cta: 'Start free trial',
        ctaLink: '/resources',
        highlighted: false,
    },
    {
        name: 'Team',
        price: '$499',
        period: '/month',
        description: 'For growing teams that need dynamic secrets and Kubernetes integration.',
        features: ['Up to 10,000 secrets', '25 users included', 'Dynamic secrets', 'Kubernetes integration', 'Email support'],
        cta: 'Start free trial',
        ctaLink: '/resources',
        highlighted: false,
    },
    {
        name: 'Business',
        price: '$1,499',
        period: '/month',
        description: 'For organizations requiring PKI, CI/CD integration, and SSO.',
        features: ['Up to 50,000 secrets', '100 users included', 'PKI & certificate authority', 'CI/CD pipeline integration', 'SSO & priority support'],
        cta: 'Start free trial',
        ctaLink: '/resources',
        highlighted: true,
    },
    {
        name: 'Enterprise',
        price: 'Custom',
        period: '',
        description: 'For large organizations with custom requirements and unlimited scale.',
        features: ['Unlimited secrets', 'Unlimited users', 'Dedicated support engineer', 'Custom integrations', 'SLA & compliance packages'],
        cta: 'Contact sales',
        ctaLink: '/company/contact',
        highlighted: false,
    },
];
---

<Layout title="Mimir - Secrets Management | NornCorp" description="Enterprise-grade secrets management for modern infrastructure. Secure, scalable, and simple.">
    <Header client:load />

    <ProductHero
        client:load
        title="Secure secrets management for the modern enterprise"
        description="Keep your secrets secure with enterprise-grade encryption, fine-grained access control, and seamless integration with your existing infrastructure."
        screenshot="https://tailwindcss.com/plus-assets/img/component-images/dark-project-app-screenshot.png"
    />

    <main class="isolate">
        <!-- Features Section -->
        <div class="bg-norn-darker py-24 sm:py-32">
            <div class="mx-auto max-w-7xl px-6 lg:px-8">
                <div class="mx-auto max-w-2xl lg:text-center">
                    <h2 class="text-base/7 font-semibold text-norn-green">Enterprise Security</h2>
                    <p class="mt-2 text-3xl font-semibold tracking-tight text-pretty text-white sm:text-4xl">
                        Everything you need to manage secrets at scale
                    </p>
                    <p class="mt-6 text-lg/8 text-gray-300">
                        Mimir provides the tools and controls your team needs to securely store, access, and rotate secrets across your entire infrastructure.
                    </p>
                </div>
                <div class="mx-auto mt-16 max-w-2xl sm:mt-20 lg:mt-24 lg:max-w-4xl">
                    <dl class="grid max-w-xl grid-cols-1 gap-x-8 gap-y-10 lg:max-w-none lg:grid-cols-2 lg:gap-y-16">
                        <div class="relative pl-16">
                            <dt class="text-base/7 font-semibold text-white">
                                <div class="absolute top-0 left-0 flex size-10 items-center justify-center rounded-lg bg-norn-green">
                                    <svg class="size-6 text-norn-dark" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" />
                                    </svg>
                                </div>
                                Encrypted Storage
                            </dt>
                            <dd class="mt-2 text-base/7 text-gray-400">
                                All secrets are encrypted at rest and in transit using industry-standard encryption algorithms.
                            </dd>
                        </div>
                        <div class="relative pl-16">
                            <dt class="text-base/7 font-semibold text-white">
                                <div class="absolute top-0 left-0 flex size-10 items-center justify-center rounded-lg bg-norn-green">
                                    <svg class="size-6 text-norn-dark" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
                                    </svg>
                                </div>
                                Access Control
                            </dt>
                            <dd class="mt-2 text-base/7 text-gray-400">
                                Fine-grained policies ensure only authorized users and services can access specific secrets.
                            </dd>
                        </div>
                        <div class="relative pl-16">
                            <dt class="text-base/7 font-semibold text-white">
                                <div class="absolute top-0 left-0 flex size-10 items-center justify-center rounded-lg bg-norn-green">
                                    <svg class="size-6 text-norn-dark" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99" />
                                    </svg>
                                </div>
                                Automatic Rotation
                            </dt>
                            <dd class="mt-2 text-base/7 text-gray-400">
                                Configure automatic rotation policies to keep your secrets fresh and secure.
                            </dd>
                        </div>
                        <div class="relative pl-16">
                            <dt class="text-base/7 font-semibold text-white">
                                <div class="absolute top-0 left-0 flex size-10 items-center justify-center rounded-lg bg-norn-green">
                                    <svg class="size-6 text-norn-dark" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                                    </svg>
                                </div>
                                Audit Logging
                            </dt>
                            <dd class="mt-2 text-base/7 text-gray-400">
                                Complete audit trail of all secret access and modifications for compliance and security.
                            </dd>
                        </div>
                    </dl>
                </div>
            </div>
        </div>

        <!-- Bento Grid -->
        <div class="bg-norn-darker">
            <div class="relative isolate overflow-hidden py-24 sm:py-32">
                <div class="mx-auto max-w-2xl px-6 lg:max-w-7xl lg:px-8">
                    <h2 class="text-center text-base/7 font-semibold text-norn-green">Secure at Scale</h2>
                    <p class="mx-auto mt-2 max-w-lg text-center text-4xl font-semibold tracking-tight text-balance text-white sm:text-5xl">
                        Everything you need to manage secrets
                    </p>
                    <div class="mt-10 grid gap-4 sm:mt-16 lg:grid-cols-3 lg:grid-rows-2">
                        <div class="relative lg:row-span-2">
                            <div class="absolute inset-px rounded-lg bg-norn-darker ring-1 ring-white/10 lg:rounded-l-4xl" />
                            <div class="relative flex h-full flex-col overflow-hidden rounded-[calc(var(--radius-lg)+1px)] lg:rounded-l-[calc(2rem+1px)]">
                                <div class="px-8 pt-8 pb-3 sm:px-10 sm:pt-10 sm:pb-0">
                                    <p class="mt-2 text-lg font-medium tracking-tight text-white max-lg:text-center">
                                        CLI & API Access
                                    </p>
                                    <p class="mt-2 max-w-lg text-sm/6 text-gray-400 max-lg:text-center">
                                        Access your secrets from anywhere using our intuitive CLI or integrate directly with our REST API.
                                    </p>
                                </div>
                                <div class="@container relative min-h-120 w-full grow max-lg:mx-auto max-lg:max-w-sm">
                                    <div class="absolute inset-x-10 top-10 bottom-0 overflow-hidden rounded-t-[12cqw] border-x-[3cqw] border-t-[3cqw] border-norn-green/30 bg-norn-darker shadow-2xl">
                                        <img
                                            alt=""
                                            src="https://tailwindcss.com/plus-assets/img/component-images/bento-03-mobile-friendly.png"
                                            class="size-full object-cover object-top"
                                            style="filter: brightness(0.75) sepia(1) hue-rotate(110deg) saturate(1.5) contrast(1.1);"
                                        />
                                    </div>
                                </div>
                            </div>
                            <div class="pointer-events-none absolute inset-px rounded-lg shadow-sm ring-1 ring-norn-green/20 lg:rounded-l-4xl" />
                        </div>
                        <div class="relative max-lg:row-start-1">
                            <div class="absolute inset-px rounded-lg bg-norn-darker ring-1 ring-white/10 max-lg:rounded-t-4xl" />
                            <div class="relative flex h-full flex-col overflow-hidden rounded-[calc(var(--radius-lg)+1px)] max-lg:rounded-t-[calc(2rem+1px)]">
                                <div class="px-8 pt-8 sm:px-10 sm:pt-10">
                                    <p class="mt-2 text-lg font-medium tracking-tight text-white max-lg:text-center">
                                        Encryption
                                    </p>
                                    <p class="mt-2 max-w-lg text-sm/6 text-gray-400 max-lg:text-center">
                                        Military-grade AES-256 encryption with automatic key rotation and hardware security module support.
                                    </p>
                                </div>
                                <div class="flex flex-1 items-center justify-center px-8 max-lg:pt-10 max-lg:pb-12 sm:px-10 lg:pb-2">
                                    <img
                                        alt=""
                                        src="https://tailwindcss.com/plus-assets/img/component-images/bento-03-performance.png"
                                        class="w-full max-lg:max-w-xs"
                                        style="filter: brightness(0.75) sepia(1) hue-rotate(110deg) saturate(1.5) contrast(1.1);"
                                    />
                                </div>
                            </div>
                            <div class="pointer-events-none absolute inset-px rounded-lg shadow-sm ring-1 ring-norn-green/20 max-lg:rounded-t-4xl" />
                        </div>
                        <div class="relative max-lg:row-start-3 lg:col-start-2 lg:row-start-2">
                            <div class="absolute inset-px rounded-lg bg-norn-darker ring-1 ring-white/10" />
                            <div class="relative flex h-full flex-col overflow-hidden rounded-[calc(var(--radius-lg)+1px)]">
                                <div class="px-8 pt-8 sm:px-10 sm:pt-10">
                                    <p class="mt-2 text-lg font-medium tracking-tight text-white max-lg:text-center">
                                        Audit Logging
                                    </p>
                                    <p class="mt-2 max-w-lg text-sm/6 text-gray-400 max-lg:text-center">
                                        Complete audit trail of all secret access and modifications for compliance and security investigations.
                                    </p>
                                </div>
                                <div class="@container flex flex-1 items-center max-lg:py-6 lg:pb-2">
                                    <img
                                        alt=""
                                        src="https://tailwindcss.com/plus-assets/img/component-images/bento-03-security.png"
                                        class="h-[min(152px,40cqw)] object-cover"
                                        style="filter: brightness(0.75) sepia(1) hue-rotate(110deg) saturate(1.5) contrast(1.1);"
                                    />
                                </div>
                            </div>
                            <div class="pointer-events-none absolute inset-px rounded-lg shadow-sm ring-1 ring-norn-green/20" />
                        </div>
                        <div class="relative lg:row-span-2">
                            <div class="absolute inset-px rounded-lg bg-norn-darker ring-1 ring-white/10 max-lg:rounded-b-4xl lg:rounded-r-4xl" />
                            <div class="relative flex h-full flex-col overflow-hidden rounded-[calc(var(--radius-lg)+1px)] max-lg:rounded-b-[calc(2rem+1px)] lg:rounded-r-[calc(2rem+1px)]">
                                <div class="px-8 pt-8 pb-3 sm:px-10 sm:pt-10 sm:pb-0">
                                    <p class="mt-2 text-lg font-medium tracking-tight text-white max-lg:text-center">
                                        Access Policies
                                    </p>
                                    <p class="mt-2 max-w-lg text-sm/6 text-gray-400 max-lg:text-center">
                                        Fine-grained access control policies ensure only authorized users and services can access specific secrets.
                                    </p>
                                </div>
                                <div class="relative min-h-120 w-full grow">
                                    <div class="absolute top-10 right-0 bottom-0 left-10 overflow-hidden rounded-tl-xl bg-norn-darker shadow-2xl ring-1 ring-norn-green/20">
                                        <div class="flex bg-norn-darker/90 ring-1 ring-norn-green/20">
                                            <div class="-mb-px flex text-sm/6 font-medium text-gray-400">
                                                <div class="border-r border-b border-r-white/10 border-b-norn-green/30 bg-norn-green/10 px-4 py-2 text-white">
                                                    policy.hcl
                                                </div>
                                                <div class="border-r border-gray-600/10 px-4 py-2">main.hcl</div>
                                            </div>
                                        </div>
                                        <div class="px-6 pt-6 pb-14">{/* Your code example */}</div>
                                    </div>
                                </div>
                            </div>
                            <div class="pointer-events-none absolute inset-px rounded-lg shadow-sm ring-1 ring-norn-green/20 max-lg:rounded-b-4xl lg:rounded-r-4xl" />
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- Pricing Section -->
        <div class="bg-norn-dark">
            <div class="mx-auto max-w-7xl px-6 lg:px-8">
                <div class="mx-auto max-w-2xl text-center">
                    <h2 class="text-base/7 font-semibold text-norn-green">Pricing</h2>
                    <p class="mt-2 text-3xl font-semibold tracking-tight text-pretty text-white sm:text-4xl">
                        Choose the right plan for your team
                    </p>
                </div>
            </div>
            <PricingTable tiers={pricingTiers} />
        </div>
    </main>

    <Footer />
</Layout>
