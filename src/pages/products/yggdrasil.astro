---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.tsx';
import Footer from '../../components/Footer.tsx';
import ProductHero from '../../components/ProductHero.tsx';
---

<Layout title="Yggdrasil - Identity-Aware Access Gateway | NornCorp" description="Zero-trust access control for modern infrastructure. Secure every connection with identity-aware policies.">
    <Header client:load />

    <ProductHero
        client:load
        title="Identity-aware access gateway"
        description="Implement zero-trust security with identity-based access control. Yggdrasil ensures every connection is authenticated, authorized, and encrypted."
        screenshot="https://tailwindcss.com/plus-assets/img/component-images/dark-project-app-screenshot.png"
    />

    <main class="isolate">
        <!-- Features Section -->
        <div class="bg-norn-darker py-24 sm:py-32">
            <div class="mx-auto max-w-7xl px-6 lg:px-8">
                <div class="mx-auto max-w-2xl lg:text-center">
                    <h2 class="text-base/7 font-semibold text-norn-green">Zero-Trust Security</h2>
                    <p class="mt-2 text-3xl font-semibold tracking-tight text-pretty text-white sm:text-4xl">
                        Secure access for your entire infrastructure
                    </p>
                    <p class="mt-6 text-lg/8 text-gray-300">
                        Yggdrasil provides identity-based access control that scales from a single service to your entire infrastructure, ensuring every connection is verified.
                    </p>
                </div>
                <div class="mx-auto mt-16 max-w-2xl sm:mt-20 lg:mt-24 lg:max-w-4xl">
                    <dl class="grid max-w-xl grid-cols-1 gap-x-8 gap-y-10 lg:max-w-none lg:grid-cols-2 lg:gap-y-16">
                        <div class="relative pl-16">
                            <dt class="text-base/7 font-semibold text-white">
                                <div class="absolute top-0 left-0 flex size-10 items-center justify-center rounded-lg bg-norn-green">
                                    <svg class="size-6 text-norn-dark" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
                                    </svg>
                                </div>
                                Identity Verification
                            </dt>
                            <dd class="mt-2 text-base/7 text-gray-400">
                                Every request is authenticated against your identity provider with multi-factor authentication support.
                            </dd>
                        </div>
                        <div class="relative pl-16">
                            <dt class="text-base/7 font-semibold text-white">
                                <div class="absolute top-0 left-0 flex size-10 items-center justify-center rounded-lg bg-norn-green">
                                    <svg class="size-6 text-norn-dark" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25ZM6.75 12h.008v.008H6.75V12Zm0 3h.008v.008H6.75V15Zm0 3h.008v.008H6.75V18Z" />
                                    </svg>
                                </div>
                                Policy Engine
                            </dt>
                            <dd class="mt-2 text-base/7 text-gray-400">
                                Define fine-grained access policies based on user identity, device posture, location, and time.
                            </dd>
                        </div>
                        <div class="relative pl-16">
                            <dt class="text-base/7 font-semibold text-white">
                                <div class="absolute top-0 left-0 flex size-10 items-center justify-center rounded-lg bg-norn-green">
                                    <svg class="size-6 text-norn-dark" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15a4.5 4.5 0 0 0 4.5 4.5H18a3.75 3.75 0 0 0 1.332-7.257 3 3 0 0 0-3.758-3.848 5.25 5.25 0 0 0-10.233 2.33A4.502 4.502 0 0 0 2.25 15Z" />
                                    </svg>
                                </div>
                                Service Mesh Integration
                            </dt>
                            <dd class="mt-2 text-base/7 text-gray-400">
                                Seamlessly integrate with Kubernetes, Istio, and other service mesh platforms.
                            </dd>
                        </div>
                        <div class="relative pl-16">
                            <dt class="text-base/7 font-semibold text-white">
                                <div class="absolute top-0 left-0 flex size-10 items-center justify-center rounded-lg bg-norn-green">
                                    <svg class="size-6 text-norn-dark" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 0 0 6 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0 1 18 16.5h-2.25m-7.5 0h7.5m-7.5 0-1 3m8.5-3 1 3m0 0 .5 1.5m-.5-1.5h-9.5m0 0-.5 1.5M9 11.25v1.5M12 9v3.75m3-6v6" />
                                    </svg>
                                </div>
                                Real-time Monitoring
                            </dt>
                            <dd class="mt-2 text-base/7 text-gray-400">
                                Monitor all access attempts in real-time with detailed logging and analytics.
                            </dd>
                        </div>
                    </dl>
                </div>
            </div>
        </div>

        <!-- Bento Grid -->
        <div class="bg-norn-darker">
            <div class="relative isolate overflow-hidden py-24 sm:py-32">
                <div class="mx-auto max-w-2xl px-6 lg:max-w-7xl lg:px-8">
                    <h2 class="text-base/7 font-semibold text-norn-green">Zero-Trust Security</h2>
                    <p class="mt-2 max-w-lg text-4xl font-semibold tracking-tight text-pretty text-white sm:text-5xl">
                        Everything you need for secure access
                    </p>
                    <div class="mt-10 grid grid-cols-1 gap-4 sm:mt-16 lg:grid-cols-6 lg:grid-rows-2">
                        <div class="flex p-px lg:col-span-4">
                            <div class="w-full overflow-hidden rounded-lg bg-norn-darker shadow-sm ring-1 ring-norn-green/20 max-lg:rounded-t-4xl lg:rounded-tl-4xl">
                                <img
                                    alt=""
                                    src="https://tailwindcss.com/plus-assets/img/component-images/dark-bento-02-releases.png"
                                    class="h-80 object-cover object-left"
                                    style="filter: brightness(0.75) sepia(1) hue-rotate(110deg) saturate(1.5) contrast(1.1);"
                                />
                                <div class="p-10">
                                    <h3 class="text-sm/4 font-semibold text-norn-green">Identity Verification</h3>
                                    <p class="mt-2 text-lg font-medium tracking-tight text-white">Multi-factor authentication</p>
                                    <p class="mt-2 max-w-lg text-sm/6 text-gray-400">
                                        Every request is authenticated with MFA, device posture checks, and continuous verification to ensure secure access.
                                    </p>
                                </div>
                            </div>
                        </div>
                        <div class="flex p-px lg:col-span-2">
                            <div class="w-full overflow-hidden rounded-lg bg-norn-darker shadow-sm ring-1 ring-norn-green/20 lg:rounded-tr-4xl">
                                <img
                                    alt=""
                                    src="https://tailwindcss.com/plus-assets/img/component-images/dark-bento-02-integrations.png"
                                    class="h-80 object-cover"
                                    style="filter: brightness(0.75) sepia(1) hue-rotate(110deg) saturate(1.5) contrast(1.1);"
                                />
                                <div class="p-10">
                                    <h3 class="text-sm/4 font-semibold text-norn-green">Service Mesh</h3>
                                    <p class="mt-2 text-lg font-medium tracking-tight text-white">
                                        Kubernetes native
                                    </p>
                                    <p class="mt-2 max-w-lg text-sm/6 text-gray-400">
                                        Seamless integration with Istio, Linkerd, and other service mesh platforms.
                                    </p>
                                </div>
                            </div>
                        </div>
                        <div class="flex p-px lg:col-span-2">
                            <div class="w-full overflow-hidden rounded-lg bg-norn-darker shadow-sm ring-1 ring-norn-green/20 lg:rounded-bl-4xl">
                                <img
                                    alt=""
                                    src="https://tailwindcss.com/plus-assets/img/component-images/dark-bento-02-security.png"
                                    class="h-80 object-cover"
                                    style="filter: brightness(0.75) sepia(1) hue-rotate(110deg) saturate(1.5) contrast(1.1);"
                                />
                                <div class="p-10">
                                    <h3 class="text-sm/4 font-semibold text-norn-green">Policy Engine</h3>
                                    <p class="mt-2 text-lg font-medium tracking-tight text-white">
                                        Fine-grained control
                                    </p>
                                    <p class="mt-2 max-w-lg text-sm/6 text-gray-400">
                                        Define access policies based on identity, device, location, and time of day.
                                    </p>
                                </div>
                            </div>
                        </div>
                        <div class="flex p-px lg:col-span-4">
                            <div class="w-full overflow-hidden rounded-lg bg-norn-darker shadow-sm ring-1 ring-norn-green/20 max-lg:rounded-b-4xl lg:rounded-br-4xl">
                                <img
                                    alt=""
                                    src="https://tailwindcss.com/plus-assets/img/component-images/dark-bento-02-performance.png"
                                    class="h-80 object-cover object-left"
                                    style="filter: brightness(0.75) sepia(1) hue-rotate(110deg) saturate(1.5) contrast(1.1);"
                                />
                                <div class="p-10">
                                    <h3 class="text-sm/4 font-semibold text-norn-green">Real-time Monitoring</h3>
                                    <p class="mt-2 text-lg font-medium tracking-tight text-white">
                                        Audit and analytics
                                    </p>
                                    <p class="mt-2 max-w-lg text-sm/6 text-gray-400">
                                        Monitor all access attempts in real-time with detailed logging, alerting, and threat detection to keep your infrastructure secure.
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <Footer />
</Layout>
