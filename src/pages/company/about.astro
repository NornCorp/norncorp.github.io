---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.tsx';
import Footer from '../../components/Footer.tsx';

const timeline = [
  {
    name: 'Founded company',
    description: 'NornCorp was founded with a mission to bring enterprise-grade security to organizations of all sizes.',
    date: 'Aug 2021',
    dateTime: '2021-08',
  },
  {
    name: 'Launched Mimir',
    description: 'Released our flagship secrets management platform, revolutionizing how teams handle sensitive credentials.',
    date: 'Dec 2021',
    dateTime: '2021-12',
  },
  {
    name: 'Introduced Yggdrasil',
    description: 'Launched our identity-aware access gateway, enabling zero-trust security at scale for modern infrastructure.',
    date: 'Feb 2022',
    dateTime: '2022-02',
  },
  {
    name: 'Global expansion',
    description: 'Opened offices worldwide and reached 10,000+ enterprise customers securing critical infrastructure.',
    date: 'Dec 2022',
    dateTime: '2022-12',
  },
];

const jobOpenings = [
  {
    id: 1,
    role: 'Senior Security Engineer',
    href: '#',
    description: 'Build the next generation of security infrastructure. Work on cutting-edge cryptography and access control systems.',
    salary: '$150,000 - $200,000 USD',
    location: 'San Francisco, CA',
  },
  {
    id: 2,
    role: 'DevOps Engineer',
    href: '#',
    description: 'Scale our Kubernetes infrastructure and help customers deploy secure, reliable systems at global scale.',
    salary: '$140,000 - $180,000 USD',
    location: 'Remote',
  },
  {
    id: 3,
    role: 'Product Manager',
    href: '#',
    description: 'Drive product strategy for our security platform. Work with customers to understand their needs and shape our roadmap.',
    salary: '$160,000 - $210,000 USD',
    location: 'New York, NY',
  },
];
---

<Layout title="About Us - NornCorp" description="Learn about NornCorp's mission to secure the modern enterprise with cutting-edge infrastructure security.">
    <Header client:load />

    <main class="isolate">
        <!-- Hero section -->
        <div class="bg-norn-dark">
            <div class="relative isolate overflow-hidden bg-gradient-to-b from-norn-green/5">
                <div
                    aria-hidden="true"
                    class="absolute inset-y-0 right-1/2 -z-10 -mr-96 w-[200%] origin-top-right skew-x-[-30deg] bg-norn-darker shadow-xl ring-1 shadow-norn-green/10 ring-white/5 sm:-mr-80 lg:-mr-96"
                />
                <div class="mx-auto max-w-7xl px-6 py-32 sm:py-40 lg:px-8">
                    <div class="mx-auto max-w-2xl lg:mx-0 lg:grid lg:max-w-none lg:grid-cols-2 lg:gap-x-16 lg:gap-y-8 xl:grid-cols-1 xl:grid-rows-1 xl:gap-x-8">
                        <h1 class="max-w-2xl text-5xl font-semibold tracking-tight text-balance text-white sm:text-7xl lg:col-span-2 xl:col-auto">
                            Building the security infrastructure for tomorrow's enterprises
                        </h1>
                        <div class="mt-6 max-w-xl lg:mt-0 xl:col-end-1 xl:row-start-1">
                            <p class="text-lg text-pretty text-gray-400 sm:text-xl/8">
                                At NornCorp, we believe security shouldn't be an afterthought. We're building the tools that empower teams to secure their infrastructure from the ground up, with secrets management and identity-aware access control that scales with your organization.
                            </p>
                        </div>
                        <img
                            alt="Team collaboration"
                            src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?ixlib=rb-4.0.3&auto=format&fit=crop&w=1280&q=80"
                            class="mt-10 aspect-6/5 w-full max-w-lg rounded-2xl object-cover ring-1 ring-white/10 sm:mt-16 lg:mt-0 lg:max-w-none xl:row-span-2 xl:row-end-2 xl:mt-36"
                        />
                    </div>
                </div>
                <div class="absolute inset-x-0 bottom-0 -z-10 h-24 bg-gradient-to-t from-norn-dark sm:h-32"></div>
            </div>
        </div>

        <!-- Timeline section -->
        <div class="bg-norn-dark py-24 sm:py-32">
            <div class="mx-auto max-w-7xl px-6 lg:px-8">
                <div class="mx-auto grid max-w-2xl grid-cols-1 gap-8 overflow-hidden lg:mx-0 lg:max-w-none lg:grid-cols-4">
                    {timeline.map((item) => (
                        <div key={item.name}>
                            <time
                                datetime={item.dateTime}
                                class="flex items-center text-sm/6 font-semibold text-norn-green-light"
                            >
                                <svg viewBox="0 0 4 4" aria-hidden="true" class="mr-4 size-1 flex-none">
                                    <circle r={2} cx={2} cy={2} fill="currentColor" />
                                </svg>
                                {item.date}
                                <div
                                    aria-hidden="true"
                                    class="absolute -ml-2 h-px w-screen -translate-x-full bg-white/10 sm:-ml-4 lg:static lg:-mr-6 lg:ml-8 lg:w-auto lg:flex-auto lg:translate-x-0"
                                />
                            </time>
                            <p class="mt-6 text-lg/8 font-semibold tracking-tight text-white">{item.name}</p>
                            <p class="mt-1 text-base/7 text-gray-400">{item.description}</p>
                        </div>
                    ))}
                </div>
            </div>
        </div>

        <!-- Logo cloud -->
        <div class="bg-norn-dark">
            <div class="mx-auto mt-32 max-w-7xl sm:mt-40 sm:px-6 lg:px-8">
                <div class="relative isolate overflow-hidden bg-norn-darker px-6 py-24 text-center shadow-2xl ring-1 ring-white/10 sm:rounded-3xl sm:px-16">
                    <h2 class="mx-auto max-w-2xl text-3xl font-bold tracking-tight text-white sm:text-4xl">
                        Trusted by security-conscious teams worldwide
                    </h2>
                    <p class="mx-auto mt-6 max-w-xl text-lg/8 text-gray-300">
                        From startups to Fortune 500 companies, organizations rely on NornCorp to secure their most critical infrastructure and secrets.
                    </p>
                    <div class="mx-auto mt-20 grid max-w-lg grid-cols-4 items-center gap-x-8 gap-y-12 sm:max-w-xl sm:grid-cols-6 sm:gap-x-10 sm:gap-y-14 lg:max-w-4xl lg:grid-cols-5">
                        <img
                            alt="Transistor"
                            src="https://tailwindcss.com/plus-assets/img/logos/158x48/transistor-logo-white.svg"
                            width="158"
                            height="48"
                            class="col-span-2 max-h-12 w-full object-contain lg:col-span-1"
                        />
                        <img
                            alt="Reform"
                            src="https://tailwindcss.com/plus-assets/img/logos/158x48/reform-logo-white.svg"
                            width="158"
                            height="48"
                            class="col-span-2 max-h-12 w-full object-contain lg:col-span-1"
                        />
                        <img
                            alt="Tuple"
                            src="https://tailwindcss.com/plus-assets/img/logos/158x48/tuple-logo-white.svg"
                            width="158"
                            height="48"
                            class="col-span-2 max-h-12 w-full object-contain lg:col-span-1"
                        />
                        <img
                            alt="SavvyCal"
                            src="https://tailwindcss.com/plus-assets/img/logos/158x48/savvycal-logo-white.svg"
                            width="158"
                            height="48"
                            class="col-span-2 max-h-12 w-full object-contain sm:col-start-2 lg:col-span-1"
                        />
                        <img
                            alt="Statamic"
                            src="https://tailwindcss.com/plus-assets/img/logos/158x48/statamic-logo-white.svg"
                            width="158"
                            height="48"
                            class="col-span-2 col-start-2 max-h-12 w-full object-contain sm:col-start-auto lg:col-span-1"
                        />
                    </div>
                </div>
            </div>
        </div>

        <!-- Team section -->
        <div class="bg-norn-dark mt-32 overflow-hidden sm:mt-40">
            <div class="mx-auto max-w-7xl px-6 lg:flex lg:px-8">
                <div class="mx-auto grid max-w-2xl grid-cols-1 gap-x-12 gap-y-16 lg:mx-0 lg:max-w-none lg:min-w-full lg:flex-none lg:gap-y-8">
                    <div class="lg:col-end-1 lg:w-full lg:max-w-lg lg:pb-8">
                        <h2 class="text-4xl font-semibold tracking-tight text-white sm:text-5xl">
                            Our people
                        </h2>
                        <p class="mt-6 text-xl/8 text-gray-300">
                            We're a distributed team of security experts, engineers, and designers passionate about making the internet more secure. Our team brings decades of combined experience from leading security and infrastructure companies.
                        </p>
                        <p class="mt-6 text-base/7 text-gray-400">
                            We believe that great security comes from diverse perspectives. Our team represents different backgrounds, experiences, and approaches to solving hard problems.
                        </p>
                    </div>
                    <div class="flex flex-wrap items-start justify-end gap-6 sm:gap-8 lg:contents">
                        <div class="w-0 flex-auto lg:ml-auto lg:w-auto lg:flex-none lg:self-end">
                            <img
                                alt="Team members collaborating"
                                src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?ixlib=rb-4.0.3&auto=format&fit=crop&w=1152&q=80"
                                class="aspect-7/5 w-148 max-w-none rounded-2xl bg-gray-800 object-cover ring-1 ring-white/10 max-sm:w-120"
                            />
                        </div>
                        <div class="contents lg:col-span-2 lg:col-end-2 lg:ml-auto lg:flex lg:w-148 lg:items-start lg:justify-end lg:gap-x-8">
                            <div class="order-first flex w-64 flex-none justify-end self-end max-sm:w-40 lg:w-auto">
                                <img
                                    alt="Team workshop"
                                    src="https://images.unsplash.com/photo-1557804506-669a67965ba0?ixlib=rb-4.0.3&auto=format&fit=crop&w=768&h=604&q=80"
                                    class="aspect-4/3 w-[24rem] max-w-none flex-none rounded-2xl bg-gray-800 object-cover ring-1 ring-white/10"
                                />
                            </div>
                            <div class="flex w-96 flex-auto justify-end lg:w-auto lg:flex-none">
                                <img
                                    alt="Office environment"
                                    src="https://images.unsplash.com/photo-1542744173-8e7e53415bb0?ixlib=rb-4.0.3&auto=format&fit=crop&w=1152&h=842&q=80"
                                    class="aspect-7/5 w-148 max-w-none flex-none rounded-2xl bg-gray-800 object-cover ring-1 ring-white/10 max-sm:w-120"
                                />
                            </div>
                            <div class="hidden sm:block sm:w-0 sm:flex-auto lg:w-auto lg:flex-none">
                                <img
                                    alt="Team discussion"
                                    src="https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?ixlib=rb-4.0.3&auto=format&fit=crop&w=768&h=604&q=80"
                                    class="aspect-4/3 w-[24rem] max-w-none rounded-2xl bg-gray-800 object-cover ring-1 ring-white/10"
                                />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Stats -->
        <div class="bg-norn-dark">
            <div class="mx-auto mt-32 max-w-7xl px-6 sm:mt-40 lg:px-8">
                <div class="mx-auto max-w-2xl lg:mx-0">
                    <h2 class="text-4xl font-semibold tracking-tight text-pretty text-white sm:text-5xl">
                        Security at scale, impact that matters
                    </h2>
                    <p class="mt-6 text-base/7 text-gray-300">
                        Our platform secures critical infrastructure for thousands of companies, protecting billions of secrets and access requests every day.
                    </p>
                </div>
                <div class="mx-auto mt-16 flex max-w-2xl flex-col gap-8 lg:mx-0 lg:mt-20 lg:max-w-none lg:flex-row lg:items-end">
                    <div class="flex flex-col-reverse justify-between gap-x-16 gap-y-8 rounded-2xl bg-norn-darker/50 p-8 ring-1 ring-white/10 sm:w-3/4 sm:max-w-md sm:flex-row-reverse sm:items-end lg:w-72 lg:max-w-none lg:flex-none lg:flex-col lg:items-start">
                        <p class="flex-none text-3xl font-bold tracking-tight text-white">10,000+</p>
                        <div class="sm:w-80 sm:shrink lg:w-auto lg:flex-none">
                            <p class="text-lg font-semibold tracking-tight text-white">
                                Enterprise customers
                            </p>
                            <p class="mt-2 text-base/7 text-gray-300">
                                Organizations trust NornCorp to secure their infrastructure.
                            </p>
                        </div>
                    </div>
                    <div class="flex flex-col-reverse justify-between gap-x-16 gap-y-8 rounded-2xl bg-norn-green/10 p-8 ring-1 ring-norn-green/25 sm:flex-row-reverse sm:items-end lg:w-full lg:max-w-sm lg:flex-auto lg:flex-col lg:items-start lg:gap-y-44">
                        <p class="flex-none text-3xl font-bold tracking-tight text-white">5 billion+</p>
                        <div class="sm:w-80 sm:shrink lg:w-auto lg:flex-none">
                            <p class="text-lg font-semibold tracking-tight text-white">
                                Secrets protected daily across our platform
                            </p>
                            <p class="mt-2 text-base/7 text-gray-300">
                                From API keys to database credentials, we keep them secure.
                            </p>
                        </div>
                    </div>
                    <div class="flex flex-col-reverse justify-between gap-x-16 gap-y-8 rounded-2xl bg-norn-green p-8 sm:w-11/12 sm:max-w-xl sm:flex-row-reverse sm:items-end lg:w-full lg:max-w-none lg:flex-auto lg:flex-col lg:items-start lg:gap-y-28">
                        <p class="flex-none text-3xl font-bold tracking-tight text-norn-dark">99.99%</p>
                        <div class="sm:w-80 sm:shrink lg:w-auto lg:flex-none">
                            <p class="text-lg font-semibold tracking-tight text-norn-dark">Platform uptime SLA</p>
                            <p class="mt-2 text-base/7 text-norn-dark/80">
                                We take reliability seriously. Your security infrastructure is always available when you need it.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Careers section -->
        <div class="bg-norn-darker py-32 sm:py-40">
            <div class="mx-auto max-w-7xl px-6 lg:px-8">
                <div class="mx-auto flex max-w-2xl flex-col items-end justify-between gap-16 lg:mx-0 lg:max-w-none lg:flex-row">
                    <div class="w-full lg:max-w-lg lg:flex-auto">
                        <h2 class="text-3xl font-semibold tracking-tight text-pretty text-white sm:text-4xl">
                            Join us in building the future of security
                        </h2>
                        <p class="mt-6 text-xl/8 text-gray-400">
                            We're always looking for talented engineers, designers, and security experts who share our passion for making the internet more secure.
                        </p>
                        <img
                            alt="Team working together"
                            src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?ixlib=rb-4.0.3&auto=format&fit=crop&w=1344&h=1104&q=80"
                            class="mt-16 aspect-6/5 w-full rounded-2xl object-cover ring-1 ring-white/10 lg:aspect-auto lg:h-138"
                        />
                    </div>
                    <div class="w-full lg:max-w-xl lg:flex-auto">
                        <h3 class="sr-only">Job openings</h3>
                        <ul class="-my-8 divide-y divide-white/10">
                            {jobOpenings.map((opening) => (
                                <li key={opening.id} class="py-8">
                                    <dl class="relative flex flex-wrap gap-x-3">
                                        <dt class="sr-only">Role</dt>
                                        <dd class="w-full flex-none text-lg font-semibold tracking-tight text-white">
                                            <a href={opening.href}>
                                                {opening.role}
                                                <span aria-hidden="true" class="absolute inset-0" />
                                            </a>
                                        </dd>
                                        <dt class="sr-only">Description</dt>
                                        <dd class="mt-2 w-full flex-none text-base/7 text-gray-400">
                                            {opening.description}
                                        </dd>
                                        <dt class="sr-only">Salary</dt>
                                        <dd class="mt-4 text-base/7 font-semibold text-white">{opening.salary}</dd>
                                        <dt class="sr-only">Location</dt>
                                        <dd class="mt-4 flex items-center gap-x-3 text-base/7 text-gray-400">
                                            <svg
                                                viewBox="0 0 2 2"
                                                aria-hidden="true"
                                                class="size-0.5 flex-none fill-gray-600"
                                            >
                                                <circle r={1} cx={1} cy={1} />
                                            </svg>
                                            {opening.location}
                                        </dd>
                                    </dl>
                                </li>
                            ))}
                        </ul>
                        <div class="mt-8 flex border-t border-white/10 pt-8">
                            <a
                                href="/company/careers"
                                class="text-sm/6 font-semibold text-norn-green hover:text-norn-green-light"
                            >
                                View all openings <span aria-hidden="true">&rarr;</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <Footer />
</Layout>
